# AgentGate — copy this file to .env and fill in your values

# Required for Tier 2 LLM-as-judge (semantic evaluation of ambiguous tool calls).
# If your agent already uses OpenAI, this is the same key — no extra account needed.
# If your agent uses Anthropic, Gemini, or a local model, use the judge config below.
OPENAI_API_KEY=sk-...

# Optional: point the Tier 2 judge at a different model provider.
# Any OpenAI-compatible endpoint works (Anthropic, Together AI, Ollama, etc.)
# AGENTGATE_JUDGE_API_KEY=your-other-provider-key
# AGENTGATE_JUDGE_BASE_URL=https://api.anthropic.com/v1

# Optional: Supabase credentials for real-time audit logging
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your-anon-key

# Optional: set to WARNING in production to reduce noise
AGENTGATE_LOG_LEVEL=INFO
